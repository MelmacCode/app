# ============================================
# LA TAZA NÓMADA — Variables de Entorno
# ============================================

# WhatsApp Business (número con código de país, sin + ni espacios)
# Ejemplo: 584121234567 para Venezuela, 5215512345678 para México
VITE_WHATSAPP_NUMBER=584121234567

# Formspree (regístrate gratis en https://formspree.io)
# Form ID: los últimos caracteres de tu URL de Formspree
VITE_FORMSPREE_ID=your_form_id_here

# URL del sitio (para SEO canonical y OG tags)
VITE_SITE_URL=https://latazanomada.com

# ============================================
# FASE 2 — Supabase (descomentar cuando llegue)
# ============================================
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key

# ============================================
# FASE 2 — Sanity CMS (descomentar cuando llegue)
# ============================================
# VITE_SANITY_PROJECT_ID=your_project_id
# VITE_SANITY_DATASET=production
# VITE_SANITY_API_VERSION=2024-01-01